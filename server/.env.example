# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/leadmanager

# JWT Secret for access tokens (short-lived, 15 minutes by default)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT access token expiry (e.g. 15m, 1h)
JWT_EXPIRES_IN=15m

# JWT Secret for refresh tokens (can be different from JWT_SECRET)
JWT_REFRESH_SECRET=your_different_refresh_secret_here

# JWT refresh token expiry (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# Server Port
PORT=5000

# Client origin for CORS (e.g., https://your-vercel-app.vercel.app)
CLIENT_ORIGIN=http://localhost:5173

# Node environment (development | production)
NODE_ENV=development

# ── Email (Nodemailer SMTP) ───────────────────────────────
# Leave blank to disable emails (dev mode — logs to console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=LeadFlow <no-reply@leadflow.app>

# ── Webhooks ──────────────────────────────────────────────
# Secret for HMAC-SHA256 signature verification on inbound webhooks
WEBHOOK_SECRET=your_webhook_secret_here
# MongoDB _id of the user who will own all webhook-captured leads
WEBHOOK_OWNER_ID=
