{
  "name": "lead-manager-server",
  "version": "1.0.0",
  "description": "Lead Management System - Express + MongoDB Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "1.10.0",
    "nodemailer": "6.9.16",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "7.1.0"
  }
}
