# ── Dependencies ───────────────────────────────────────────
node_modules/
*/node_modules/
**/node_modules/

# ── Environment variables — NEVER commit real secrets ───────
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
server/.env
client/.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ── Build output ────────────────────────────────────────────
dist/
build/
client/dist/
client/build/
.output/
.nuxt/
.next/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server/logs/

# ── Certificates & Keys ─────────────────────────────────────
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ── IDE & Editor ────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

